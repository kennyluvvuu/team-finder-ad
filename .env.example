# --- Django Backend Settings ---
DJANGO_SECRET_KEY=django-insecure-change-this-key-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,web
# TASK_VERSION=3 (Var 3 focus: Skill tags and project skills filtering)
TASK_VERSION=3

# --- PostgreSQL Database Settings ---
POSTGRES_DB=team_finder
POSTGRES_USER=team_finder
POSTGRES_PASSWORD=team_finder_secure_pass
# Use "db" when running via Docker Compose (the container service name)
# Use "localhost" when running the Django app locally outside of Docker
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Frontend Settings ---
# URL of the Django backend container as resolved by the frontend container
BACKEND_URL=http://backend:8000

# --- Caddy / Reverse Proxy Settings ---
# Domain name for Caddy automatic SSL (e.g. site.com, teamfinder.local, or localhost)
SITE_DOMAIN=localhost
